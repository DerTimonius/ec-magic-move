{
	"name": "ec-magic-move",
	"description": "A port of shiki-magic-move as a plugin for Expressive Code",
	"keywords": [
		"expressive code",
		"starlight",
		"astro",
		"code block",
		"code animation",
		"animation",
		"shiki-magic-move"
	],
	"version": "1.0.0",
	"license": "MIT",
	"author": "Timon Jurschitsch <contact@dertimonius.eu>",
	"home": "https://github.com/DerTimonius/ec-magic-move",
	"bugs": {
		"url": "https://github.com/DerTimonius/ec-magic-move"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DerTimonius/ec-magic-move.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.mjs"
		}
	},
	"publishConfig": {
		"provenance": true
	},
	"scripts": {
		"format": "biome format --write",
		"format:check": "biome format",
		"lint": "biome lint --write",
		"lint:check": "biome lint",
		"typecheck": "tsc --noEmit",
		"build:js": "node src/js-module/build.mjs",
		"build": "pnpm build:js && tsdown",
		"dev": "tsdown --watch ./src",
		"test": "vitest",
		"release": "pnpm build && changeset version && changeset publish",
		"check": "biome check && tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@changesets/cli": "^2.30.0",
		"@expressive-code/core": "^0.41.7",
		"@expressive-code/plugin-shiki": "^0.41.7",
		"esbuild": "^0.27.4",
		"tsdown": "0.21.0-beta.2",
		"typescript": "^5.9.3",
		"vitest": "^4.1.1"
	},
	"peerDependencies": {
		"@expressive-code/core": "^0.41.7",
		"@expressive-code/plugin-shiki": "^0.41.7",
		"shiki": "^4.0.2"
	},
	"packageManager": "pnpm@10.30.3",
	"dependencies": {
		"shiki-magic-move": "^1.3.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}

{
	"include": ["src"],
	"exclude": ["src/js-module/magic-move.js", "src/js-module/build.mjs"],
	"compilerOptions": {
		"allowJs": true,
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"exactOptionalPropertyTypes": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"moduleResolution": "node",
		"module": "ESNext",
		"target": "ESNext",
		"outDir": "./dist"
	}
}
